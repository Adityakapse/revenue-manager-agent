# Copy this file to .env and fill in real values. NEVER commit .env (it's gitignored).

# Local Postgres (from docker-compose.yml). For Neon in Phase 4, swap this for the Neon URL.
DATABASE_URL=postgresql://hackathon:hackathon@localhost:5432/hotel_hackathon

# --- LLM provider: choose 'google' (recommended, generous free tier) or 'groq' ---
LLM_PROVIDER=google

# Option A — Google Gemini (recommended). Free key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-flash-latest

# Option B — Groq. Free key: https://console.groq.com  (free tier ~12K TPM is tight for the agent)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Phase 4 deploy: HTTP basic auth for the public agent URL ---
BASIC_AUTH_USER=gm
BASIC_AUTH_PASSWORD=
